{
    "compilerOptions": {
        "module": "ESNext",
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "rootDir": "src",
        "outDir": "lib",
        "sourceMap": true,
        "strict": true,
        "target": "ESNext",
        "moduleResolution": "Bundler",
        "declaration": true,
        "allowSyntheticDefaultImports": true,
        "skipLibCheck": true,
        "tsBuildInfoFile": "./lib/tsconfig.tsbuildinfo"
    },
    "compileOnSave": true,
    "include": ["src"]
}
